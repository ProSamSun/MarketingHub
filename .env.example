# ── Core ─────────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=your-dashboard-password

# ── Database (Neon Postgres) ──────────────────────────────────────────────────
# Get from: https://neon.tech → New Project → copy the connection string
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Get from: https://twilio.com → Console Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=you@yourdomain.com

# ── Meta Webhooks ─────────────────────────────────────────────────────────────
META_WEBHOOK_VERIFY_TOKEN=your-meta-verify-token

# ── GoHighLevel (optional — only if you still want GHL sync) ─────────────────
# GHL_API_KEY=
# GHL_LOCATION_ID=
# GHL_META_WORKFLOW_ID=
