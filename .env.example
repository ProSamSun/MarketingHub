# ── Core ─────────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=your-dashboard-password

# ── Database (Neon Postgres) ──────────────────────────────────────────────────
# Get from: https://neon.tech → New Project → copy the connection string
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Get from: https://twilio.com → Console Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=you@yourdomain.com

# ── Meta Webhooks ─────────────────────────────────────────────────────────────
META_WEBHOOK_VERIFY_TOKEN=your-meta-verify-token

# ── Scheduler (real-time drip cadence) ────────────────────────────────────────
# Point an external scheduler (e.g. cron-job.org) at GET /api/cron every 2-3 min
# with header  x-dashboard-token: <CRON_SECRET>  so sub-day follow-ups fire on time.
CRON_SECRET=some-long-random-string

# ── Links / Unsubscribe ───────────────────────────────────────────────────────
# Public base URL for unsubscribe links (defaults to the Vercel deployment URL).
PUBLIC_BASE_URL=https://your-app.vercel.app
# Optional secret for signing unsubscribe tokens (defaults to DASHBOARD_PASSWORD).
UNSUBSCRIBE_SECRET=another-long-random-string

# ── GoHighLevel (optional — only if you still want GHL sync) ─────────────────
# GHL_API_KEY=
# GHL_LOCATION_ID=
# GHL_META_WORKFLOW_ID=
